# ═══════════════════════════════════════════════════════════════════
# Corvus GovCloud Environment Configuration
# Copy to .env and fill in values before deployment.
# ═══════════════════════════════════════════════════════════════════

# === Database (Azure Database for PostgreSQL, private endpoint) ===
DATABASE_URL=postgresql+asyncpg://corvus:<password>@<server>.postgres.database.usgovcloudapi.net:5432/corvus_aero

# === Azure OpenAI (REQUIRED — no Anthropic models in GovCloud) ===
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.us/
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT_GPT4O=gpt-4o
AZURE_OPENAI_DEPLOYMENT_GPT4O_MINI=gpt-4o-mini
# AZURE_OPENAI_DEPLOYMENT_O1=o1  # Uncomment when o1 is available

# === Model Aliases (maps Corvus display names to Azure models) ===
LLM_MODEL_ALIASES={"haiku":"azure-gpt4o-mini","sonnet":"azure-gpt4o","opus":"azure-gpt4o"}

# === RBAC (Azure AD) ===
RBAC_MODE=azure_ad
RBAC_AZURE_TENANT_ID=
RBAC_ADMIN_CLAIM=corvus-admin
RBAC_REVIEWER_CLAIM=corvus-reviewer

# === Access Control ===
CORVUS_ACCESS_KEY=

# === Tenant ===
TENANT_ID=corvus-aero
PORT=8002

# === Network (internal only) ===
CORS_ORIGINS=https://fluent.internal.mil
